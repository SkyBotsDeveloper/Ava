AVA_ENVIRONMENT=development
AVA_LOG_LEVEL=INFO
AVA_DEBUG=false
AVA_DATA_ROOT=
AVA_PREFERRED_BROWSER=edge
AVA_BROWSER_COMMAND_MODE=live
AVA_BROWSER_LIVE_SESSION_FIRST=true
AVA_LAUNCH_EDGE_WHEN_BROWSER_MISSING=true
AVA_GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
AVA_GEMINI_LIVE_API_VERSION=v1beta
AVA_GEMINI_API_KEY=
AVA_GEMINI_LIVE_LOCALE=en-IN
AVA_GEMINI_LIVE_VOICE_NAME=Kore
AVA_GEMINI_LIVE_ENABLE_SERVER_VAD=false
AVA_GEMINI_LIVE_VAD_PREFIX_PADDING_MS=180
AVA_GEMINI_LIVE_VAD_SILENCE_MS=700
AVA_GEMINI_LIVE_ENABLE_INPUT_TRANSCRIPTION=true
AVA_GEMINI_LIVE_ENABLE_OUTPUT_TRANSCRIPTION=true
AVA_GEMINI_LIVE_THINKING_BUDGET=0
AVA_VOICE_INPUT_SAMPLE_RATE_HZ=16000
AVA_VOICE_OUTPUT_SAMPLE_RATE_HZ=24000
AVA_VOICE_INPUT_CHUNK_MS=80
AVA_WAKEWORD_MODEL_PATHS=
AVA_WAKEWORD_TRIGGER_PHRASE=Ava
AVA_WAKEWORD_THRESHOLD=0.45
AVA_WAKEWORD_PATIENCE_FRAMES=1
AVA_OBSERVATION_ENABLED=false
AVA_OBSERVATION_SAMPLING_SECONDS=10
AVA_PUSH_TO_TALK_HOTKEY=ctrl+alt+a
AVA_MUTE_HOTKEY=ctrl+alt+x
AVA_EMERGENCY_STOP_HOTKEY=ctrl+alt+backspace
AVA_UI_AUTO_CLOSE_MS=0
